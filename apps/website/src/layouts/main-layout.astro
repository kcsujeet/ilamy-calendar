---
import { Footer } from '@/components/common/footer'
import { ModeToggle } from '@/components/common/mode-toggle'
import { Header } from '@/components/common/nav-bar'
import '../styles/globals.css'

interface Props {
	title?: string
	description?: string
	keywords?: string
	canonicalUrl?: string
	ogImage?: string
	schemaType?: string
	noIndex?: boolean
}

const {
	title = 'ilamy Calendar - Lightweight, Pluggable React Calendar Component (Tailwind CSS & shadcn/ui) | Full Calendar Alternative',
	description = 'A lightweight, highly pluggable React calendar component built with TypeScript, Tailwind CSS, and shadcn/ui. A small ~13 KB gzipped core with opt-in plugins (recurring events, agenda) so you only ship what you use. Ships no CSS — bring your own shadcn/ui design system. A modern full calendar alternative with drag-and-drop, resource scheduling, recurring events, and multi-view support for React, Next.js, and Astro.',
	keywords = 'react calendar,lightweight react calendar,pluggable calendar,plugin calendar,minimal calendar,tree shakeable calendar,headless calendar,bring your own css calendar,tailwind css calendar,shadcn calendar,shadcn/ui calendar,full calendar react,fullcalendar alternative,react big calendar,react calendar component,tailwindcss calendar,typescript calendar,nextjs calendar,astro calendar,react scheduler,event calendar react,drag drop calendar,resource calendar,calendar library react,event management,scheduling component,recurring events calendar,customizable calendar,ilamy calendar',
	canonicalUrl,
	ogImage,
	schemaType = 'SoftwareApplication',
	noIndex = false,
} = Astro.props

const logoUrl = '/ilamy.svg'
const siteUrl = 'https://ilamy.dev'
const ogType = 'website'
const ogSiteName = 'ilamy Calendar'
const currentUrl = canonicalUrl || `${siteUrl}${Astro.url.pathname}`
const imageUrl = ogImage || `${siteUrl}${logoUrl}`

// Enhanced structured data for SEO
const structuredData = {
	'@context': 'https://schema.org',
	'@type': schemaType,
	name: 'ilamy Calendar',
	alternateName: [
		'ilamy',
		'ilamy Calendar Component',
		'React Calendar Component',
	],
	description: description,
	url: siteUrl,
	applicationCategory: 'DeveloperApplication',
	operatingSystem: 'Any',
	programmingLanguage: ['JavaScript', 'TypeScript', 'React'],
	author: {
		'@type': 'Organization',
		name: 'ilamy',
		url: siteUrl,
		sameAs: [
			'https://github.com/kcsujeet/ilamy-calendar',
			'https://www.npmjs.com/package/@ilamy/calendar',
		],
	},
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'USD',
	},
	keywords: [
		'calendar',
		'react',
		'tailwind css',
		'shadcn',
		'shadcn/ui',
		'component',
		'scheduling',
		'event management',
		'typescript',
		'drag drop',
		'multi-view',
		'fullcalendar',
		'nextjs',
		'astro',
		'headless ui',
		'resource calendar',
	],
	featureList: [
		'React Calendar Component with Tailwind CSS',
		'Lightweight ~13 KB gzipped core',
		'Pluggable architecture with opt-in plugins (recurrence, agenda)',
		'Ships no CSS — bring your own shadcn/ui design system',
		'shadcn/ui Compatible Design System',
		'Full Calendar Alternative with Modern UI',
		'Event Management and Resource Scheduling',
		'Multi-locale Support and Internationalization',
		'Drag and Drop Functionality',
		'Full TypeScript Support',
		'Recurring Events Support (RRULE)',
		'Multiple View Types (Month, Week, Day, Year, Resource)',
		'Mobile Responsive Design',
		'Dark Mode Support',
		'Performance Optimized for Large Datasets',
		'Next.js and Astro Compatible',
	],
	softwareVersion: '1.0.0',
	downloadUrl: 'https://www.npmjs.com/package/@ilamy/calendar',
	supportUrl: `${siteUrl}/support`,
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': siteUrl,
	},
}
---

<html lang="en">
  <head>
    <!-- Basic Meta Tags -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Ilamy Dev" />
    <meta
      name="robots"
      content={noIndex
        ? "noindex, nofollow"
        : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"}
    />

    <!-- Canonical URL -->
    <link rel="canonical" href={currentUrl} />

    <!-- Open Graph Meta Tags -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={ogSiteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ilamy Calendar Component Preview" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@ilamy" />
    <meta name="twitter:creator" content="@ilamy" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content="ilamy Calendar Component Preview" />

    <!-- Additional SEO Meta Tags -->
    <meta name="theme-color" content="#3B82F6" />
    <meta name="msapplication-TileColor" content="#3B82F6" />
    <meta name="application-name" content="ilamy Calendar" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="ilamy Calendar" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="mobile-web-app-capable" content="yes" />

    <!-- Google Search Console verification - Get from https://search.google.com/search-console -->
    <meta
      name="google-site-verification"
      content="6lu_7Yf02vxscf3SJoQJC14KvuT4YLB_bqKMtliN2Ow"
    />

    <!-- Preconnect to external domains for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Favicon and Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Sitemap and RSS -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Structured Data for SEO -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Performance and Accessibility -->
    <meta name="referrer" content="origin-when-cross-origin" />
    <meta
      http-equiv="content-security-policy"
      content="upgrade-insecure-requests"
    />

    <!-- Theme Management Script -->
    <script is:inline>
      try {
        const theme = localStorage.getItem("ilamy-calendar-theme") || "dark";
        const root = document.documentElement;
        root.classList.remove("light", "dark");
        root.classList.add(theme);
      } catch (e) {
        // Fallback to dark theme
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>

  <body>
    <!-- Skip to main content for accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary focus:text-primary-foreground focus:rounded"
    >
      Skip to main content
    </a>

    <div class="text-foreground min-h-svh flex flex-col relative">
      <!-- SEO-optimized background elements with reduced motion preference -->
      <div
        class="fixed inset-0 -z-10 bg-linear-to-br from-background via-background to-background"
        aria-hidden="true"
      >
      </div>
      <div
        class="fixed top-0 left-1/4 -z-10 w-96 h-96 bg-blue-500/10 rounded-full filter blur-3xl animate-pulse motion-reduce:animate-none"
        aria-hidden="true"
      >
      </div>
      <div
        class="fixed bottom-0 right-1/4 -z-10 w-96 h-96 bg-indigo-500/10 rounded-full filter blur-3xl animate-pulse motion-reduce:animate-none"
        style={{ animationDelay: "2s" }}
        aria-hidden="true"
      >
      </div>
      <div
        class="fixed top-1/2 right-0 -z-10 w-72 h-72 bg-purple-500/10 rounded-full filter blur-3xl animate-pulse motion-reduce:animate-none"
        style={{ animationDelay: "4s" }}
        aria-hidden="true"
      >
      </div>
      <div
        class="fixed bottom-1/4 left-0 -z-10 w-80 h-80 bg-teal-500/10 rounded-full filter blur-3xl animate-pulse motion-reduce:animate-none"
        style={{ animationDelay: "6s" }}
        aria-hidden="true"
      >
      </div>

      <!-- Header with semantic navigation -->
      <Header pathname={Astro.url.pathname} client:load>
        <ModeToggle client:load />
      </Header>

      <!-- Main content with proper semantic structure -->
      <main id="main-content" role="main">
        <slot />
      </main>

      <!-- Footer with semantic structure -->
      <Footer />
    </div>
  </body>
</html>
