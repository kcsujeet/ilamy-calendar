{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"paths": {
			"@/*": ["./src/*"],
			"@ilamy/calendar": ["./src/index.ts"],
			"@ilamy/calendar-agenda": ["../plugins/agenda/src/index.ts"],
			"@ilamy/calendar-recurrence": ["../plugins/recurrence/src/index.ts"],
			"@ilamy/types": ["../types/src/index.ts"],
			"@ilamy/utils/dayjs": ["../utils/src/dayjs.ts"],
			"@ilamy/utils/helpers": ["../utils/src/helpers.ts"],
			"@ilamy/ui/components/*": ["../ui/src/components/*"],
			"@ilamy/ui/lib/utils": ["../ui/src/lib/utils.ts"]
		}
	},
	"include": ["**/*.ts", "**/*.tsx"],
	"exclude": ["dist", "node_modules"]
}
