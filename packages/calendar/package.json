{
	"name": "@ilamy/calendar",
	"version": "1.8.1",
	"description": "A full-featured React calendar component library built with Shadcn-Ui, Tailwind CSS, and TypeScript.",
	"author": "Sujeet Kc",
	"license": "MIT",
	"homepage": "https://ilamy.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kcsujeet/ilamy-calendar.git"
	},
	"bugs": {
		"url": "https://github.com/kcsujeet/ilamy-calendar/issues"
	},
	"keywords": [
		"react",
		"calendar",
		"typescript",
		"tailwind",
		"components",
		"shadcn",
		"radix-ui",
		"dnd-kit",
		"motion",
		"events",
		"scheduling",
		"drag-and-drop",
		"recurring-events"
	],
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./testing": {
			"types": "./dist/testing/index.d.ts",
			"import": "./dist/testing/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "CI=true NODE_ENV=production bunx bunup",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"type-check": "bunx tsc --noEmit",
		"lint": "bunx biome lint . --diagnostic-level=error",
		"check": "bunx biome check . --diagnostic-level=error",
		"check:fix": "bunx biome check --write .",
		"ci": "bun run check && bun run type-check && bun run test && bun run build",
		"prepack": "bun scripts/prepack.ts",
		"postpack": "bun scripts/postpack.ts"
	},
	"peerDependencies": {
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tailwindcss": "^4.2.2",
		"tailwindcss-animate": "^1.0.7"
	},
	"dependencies": {
		"@ilamy/ui": "workspace:*",
		"@ilamy/utils": "workspace:*",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/modifiers": "^9.0.0",
		"@radix-ui/react-popover": "^1.1.15",
		"dayjs": "^1.11.20",
		"lucide-react": "^0.475.0",
		"motion": "^12.36.0"
	},
	"devDependencies": {
		"@ilamy/calendar-recurrence": "workspace:*",
		"@ilamy/types": "workspace:*",
		"rrule": "^2.8.1"
	},
	"publishConfig": {
		"access": "public"
	}
}
