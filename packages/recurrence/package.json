{
	"name": "@ilamy/calendar-recurrence",
	"version": "1.8.1",
	"private": true,
	"description": "Recurring-events plugin for @ilamy/calendar (RFC 5545 via rrule).",
	"author": "Sujeet Kc",
	"license": "MIT",
	"homepage": "https://ilamy.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kcsujeet/ilamy-calendar.git"
	},
	"keywords": [
		"react",
		"calendar",
		"recurring-events",
		"rrule",
		"ilamy",
		"plugin"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "CI=true NODE_ENV=production bunx bunup",
		"test": "bun test",
		"type-check": "bunx tsc --noEmit",
		"lint": "bunx biome lint . --diagnostic-level=error",
		"check": "bunx biome check . --diagnostic-level=error",
		"ci": "bun run check && bun run type-check && bun run test && bun run build"
	},
	"peerDependencies": {
		"@ilamy/calendar": "workspace:*",
		"react": "^19.2.0",
		"react-dom": "^19.2.0"
	},
	"dependencies": {
		"@ilamy/ui": "workspace:*",
		"@ilamy/utils": "workspace:*",
		"rrule": "^2.8.1"
	}
}
