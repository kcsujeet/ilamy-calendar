{
	"name": "ilamy",
	"private": true,
	"type": "module",
	"description": "Monorepo for @ilamy/calendar and its plugin ecosystem.",
	"author": "Sujeet Kc",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kcsujeet/ilamy-calendar.git"
	},
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"dev": "bun run --filter '@ilamy/demo' dev",
		"build": "bun run --filter '*' --if-present build",
		"test": "bun run --filter '*' --if-present test",
		"type-check": "bun run --filter '*' --if-present type-check",
		"lint": "bunx biome lint . --diagnostic-level=error",
		"lint:fix": "bunx biome lint --write .",
		"format": "bunx biome format --write .",
		"format:check": "bunx biome format .",
		"check": "bunx biome check . --diagnostic-level=error",
		"check:fix": "bunx biome check --write .",
		"ci": "bun run check && bun run type-check && bun run test && bun run build",
		"pre-commit": "bun run check:fix",
		"prepare": "bunx husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@happy-dom/global-registrator": "^18.0.1",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/bun": "latest",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@types/rrule": "^2.2.9",
		"@vitejs/plugin-react": "^6.0.2",
		"bun-plugin-tailwind": "^0.1.2",
		"bunup": "^0.16.32",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	}
}
